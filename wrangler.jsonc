{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wake-transmission",
  "main": "worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "waking.coreyburns.ca",
      "custom_domain": true
    }
  ],
  "compatibility_date": "2024-11-01"
}
